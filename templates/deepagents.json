{
  "model": {
    "name": null,
    "api_key": null,
    "api_base": null,
    "max_tokens": 20000,
    "temperature": 0.1
  },
  
  "recursion_limit": 500,
  "debug": false,
  "name": "nanobot-deep-agent",
  
  "backend": {
    "sandbox_id": null,
    "setup_script": null,
    "restrict_to_workspace": false,
    "exec_timeout": 60,
    "path_append": ""
  },
  
  "checkpointer": {
    "type": "sqlite",
    "path": "~/.nanobot/sessions.db"
  },
  
  "skills": ["~/.nanobot/workspace/skills"],
  
  "memory": [
    {
      "type": "conversation",
      "path": "~/.nanobot/workspace/memory/MEMORY.md",
      "max_tokens": 4000,
      "enabled": true
    }
  ],
  
  "subagents": [
    {
      "name": "reply-handler",
      "description": "Handles replies to messages with full context.",
      "system_prompt": "You are a reply assistant that handles responses to specific messages. Provide relevant, contextual responses. Be concise.",
      "model": null
    }
  ],
  
  "interrupt_on": {
    "edit_file": false,
    "write_file": false,
    "execute": false,
    "all_tools": false
  },
  
  "summarization": {
    "enabled": true,
    "trigger_tokens": 100000,
    "keep_messages": 20
  },
  
  "middleware": {
    "enable_todolist": true,
    "enable_summarization": true,
    "enable_prompt_caching": true,
    "enable_skills": true,
    "enable_memory": true,
    "enable_subagents": true,
    "enable_filesystem": true
  },
  
  "task_routing": {
    "auto_delegate_reply_to": true,
    "control_commands": ["/help", "/new", "/stop", "/tasks", "/start"],
    "delegate_threshold_tokens": 1000
  },
  
  "langfuse": {
    "enabled": false,
    "public_key": null,
    "secret_key": null,
    "host": "http://localhost:3000",
    "environment": "development"
  }
}
